sh:lessThan
	a rdf:Property ;
	rdfs:label "less than"@en ;
	rdfs:comment "Specifies a property path that must have smaller values than the value nodes."@en ;
	rdfs:isDefinedBy sh: .


sh:LessThanOrEqualsConstraintComponent
