sh:equals
	a rdf:Property ;
	rdfs:label "equals"@en ;
	rdfs:comment "Specifies a property path that must have the same values as the value nodes."@en ;
	rdfs:isDefinedBy sh: .


sh:HasValueConstraintComponent
