PREFIX ex: <http://example.com/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX fruits: <http://example.com/ns/fruits/>
PREFIX olis: <https://olis.dev/>
PREFIX ont: <http://purl.org/wf4ever/wfprov>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wfdesc: <http://purl.org/wf4ever/wfdesc#>
PREFIX wfprov: <http://purl.org/wf4ever/wfprov#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

wfprov:describedByParameter
    a owl:ObjectProperty ;
    rdfs:domain wfprov:Artifact ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfdesc:Parameter ;
    schema:description "This object property is used to associate a wfprov:Artifact to the wfdesc:Parameter description." ;
    schema:name "described by parameter" ;
.

wfprov:describedByWorkflow
    a owl:ObjectProperty ;
    rdfs:domain wfprov:WorkflowRun ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfdesc:WorkflowTemplate ;
    rdfs:subPropertyOf wfprov:describedByProcess ;
    schema:description "This property associates a wfprov:WorkflowRun to its corresponding wfdesc:Workflow description." ;
    schema:name "described by workflow" ;
.

wfprov:wasEnactedBy
    a owl:ObjectProperty ;
    rdfs:domain wfprov:ProcessRun ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfprov:WorkflowEngine ;
    schema:description "wfprov:wasEnactedBy associates a wfprov:ProcessRun with a wfprov:WorkflowEngine, specifying that the execution of the process was enacted by the engine." ;
    schema:name "was enacted by" ;
.

wfprov:wasPartOfWorkflowRun
    a owl:ObjectProperty ;
    rdfs:domain wfprov:ProcessRun ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfprov:WorkflowRun ;
    schema:description "This property specifies that a wfprov:ProcessRun was executed as part of a wfprov:WorkflowRun. This typically corresponds to wfdesc:hasSubProcess in the workflow description." ;
    schema:name "was part of workflow run" ;
.

wfprov:WorkflowEngine
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:seeAlso
        wfdesc:Workflow ,
        wfprov:WorkflowRun ;
    rdfs:subClassOf foaf:Agent ;
    schema:description "A workflow engine is an foaf:Agent that is responsible for enacting a workflow definition (which could be described in a wfdesc:Workflow). The result of workflow enactment gives rise to a wfprov:WorkflowRun." ;
    schema:name "Workflow Engine" ;
.

wfprov:describedByProcess
    a owl:ObjectProperty ;
    rdfs:domain wfprov:ProcessRun ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfdesc:Process ;
    schema:description
        "This object property associate a wfprov:Processrun to its wfdesc:Process description." ,
        "Second annoying description for Issue #13 testing" ;
    schema:name "described by process" ;
.

wfprov:usedInput
    a owl:ObjectProperty ;
    rdfs:domain wfprov:ProcessRun ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfprov:Artifact ;
    schema:description "This property specifies that a wfprov:ProcessRun used an wfprov:Artifact as an input" ;
    schema:name "used input" ;
.

wfprov:wasOutputFrom
    a owl:ObjectProperty ;
    rdfs:domain wfprov:Artifact ;
    rdfs:isDefinedBy ont: ;
    rdfs:range wfprov:ProcessRun ;
    schema:description "This property specifies that a wfprov:Artifact was generated as an output from a wfprov:ProcessRun" ;
    schema:name "was output from" ;
.

wfprov:Artifact
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:seeAlso
        <http://purl.org/wf4ever/ro#ResearchObject> ,
        <http://purl.org/wf4ever/ro#Resource> ,
        wfprov:ProcessRun ,
        wfprov:usedInput ,
        wfprov:wasOutputFrom ,
        wfprov:workflowRun ;
    schema:description "Artifact is a general concept that represents immutable piece of state, which may have a physical embodiment in a physical object, or a digital representation in a computer system. In the case of wfprov, an artifact is used as input to a process run, or produced by the output of a process run." ;
    schema:name "Artifact" ;
.

wfprov:WorkflowRun
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:seeAlso
        wfdesc:Process ,
        wfdesc:Workflow ,
        wfprov:WorkflowEngine ;
    rdfs:subClassOf wfprov:ProcessRun ;
    schema:description "A workflow run is a wfprov:ProcessRun which have been enacted by a wfprov:WorkflowEngine, according to a workflow definition (which could be wfdesc:describedByWorkflow a wfdesc:Workflow). Such a process typically contains several subprocesses (wfprov:wasPartOfWorkflowRun) corresponding to wfdesc:Process descriptions" ;
    schema:name "Workflow Run" ;
.

wfprov:ProcessRun
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:seeAlso
        wfdesc:Process ,
        wfprov:Artifact ,
        wfprov:WorkflowRun ,
        wfprov:describedByProcess ,
        wfprov:usedInput ,
        wfprov:wasOutputFrom ;
    schema:description "A process run is a particular execution of a wfdesc:Process description (wfprov:describedByProcess), which can wfprov:usedInput some wfprov:Artifact instances, and produce new artifacts (wfprov:wasOutputFrom). A wfprov:WorkflowRun is a specialisation of this class." ;
    schema:name "Process Run" ;
.


# Fruits
# ├── Berry
# │   ├── Grape
# │   └── Tomato
# ├── Pome
# │   ├── Apple
# │   │   ├── Gala
# │   │   └── Granny Smith
# │   ├── Pear
# ├── Citrus
# │   ├── Orange
# │   └── Lemon

fruits:Berry
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    schema:description "Dummy desc" ;
    schema:name "Berry" ;
.

fruits:Grape
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Berry ;
    schema:description "Dummy desc" ;
    schema:name "Grape" ;
.

fruits:Tomato
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Berry ;
    schema:description "Dummy desc" ;
    schema:name "Tomato" ;
.

fruits:Pome
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits: ;
    schema:description "Dummy desc" ;
    schema:name "Pome" ;
.

fruits:Apple
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Pome ;
    schema:description "Dummy desc" ;
    schema:name "Apple" ;
.

fruits:Gala
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Apple ;
    schema:description "Dummy desc" ;
    schema:name "Gala" ;
.

fruits:GrannySmith
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Apple ;
    schema:description "Dummy desc" ;
    schema:name "Granny Smith" ;
.

fruits:Pear
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Pome ;
    schema:description "Dummy desc" ;
    schema:name "Pear" ;
.

fruits:Citrus
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits: ;
    schema:description "Dummy desc" ;
    schema:name "Citrus" ;
.

fruits:Orange
    a rdfs:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Citrus ;
    schema:description "Dummy desc" ;
    schema:name "Orange" ;
.

fruits:Lemon
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf fruits:Citrus ;
    schema:description "Dummy desc" ;
    schema:name "Lemon" ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onClass [
            a owl:Class ;
            owl:unionOf (
                fruits:Apple
                fruits:Orange
            ) ;
        ] ;
        owl:onProperty fruits:notSameColourAs ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    ] ;
.

wfprov:auspixDggsLiteral
    a rdfs:Datatype ;
    rdfs:isDefinedBy ont: ;
    rdfs:seeAlso "https://github.com/GeoscienceAustralia/AusPIX_DGGS"^^xsd:anyURI ;
    skos:definition """A textual serialization of an AusPix Discrete Global Grid System (DGGS) geometry object."""@en ;
    skos:example """ "OrdinateList (R3234)"^^geo:auspixDggsLiteral""" ;
    skos:scopeNote "This datatype is to be used only for a specific DGGS implementation - AusPix. Other DGGS implementations should declare their own datatypes." ;
    skos:prefLabel "AusPIX DGGS Literal"@en ;
.

ex:input
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:domain fruits:Lemon ;
    rdfs:range [
        a rdfs:Datatype ;
        owl:onDatatype xsd:integer ;
        owl:withRestrictions (
            [ xsd:minInclusive 0 ]
            [ xsd:maxExclusive 42 ]
        )
    ] ;
    skos:definition """An example datatype property with a range restriction of >= 0 and < 42"""@en ;
    skos:prefLabel "input"@en ;
.

ex:input2
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:domain fruits:Lemon ;
    rdfs:range [
        a rdfs:Datatype ;
        owl:onDatatype xsd:integer ;
        owl:withRestrictions (
            [ xsd:maxInclusive 42 ]
        )
    ] ;
    skos:definition """An example datatype property with a range restriction of <= 42>"""@en ;
    skos:prefLabel "input 2"@en ;
.

ex:output
    a owl:ObjectProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:range fruits:Lemon ;
    skos:definition """An example object property with a range class fruits:Lemon"""@en ;
    skos:prefLabel "output"@en ;
.

ont:
    a owl:Ontology ;
    rdfs:seeAlso <http://purl.org/wf4ever/ro> ;
    owl:imports
        <http://purl.org/wf4ever/wfdesc> ,
        foaf: ;
    owl:versionIRI <https://raw.github.com/wf4ever/ro/0.1.1/wfprov.owl> ;
    owl:versionInfo "0.1.1"^^xsd:string ;
    schema:codeRepository "https://github.com/RDFLib/pyLODE/"^^xsd:anyURI ;
    schema:contributor <https://ror.org/00yczwp93> ;
    schema:copyrightHolder <https://wf4ever.github.io> ;
    schema:creator <https://wf4ever.github.io> ;
    schema:dateCreated "2025-12-19"^^xsd:date ;
    schema:dateIssued "2025-12-19"^^xsd:date ;
    schema:dateModified "2025-12-19"^^xsd:date ;
    schema:description """The wfprov ontology shows how to express minimal provenance information about the execution of a workflow described using the wf ontology.

Here the concern is mainly the provenance which affects the research object, so in particular how some ro:Resource's might have been generated or used by the execution of a wfdesc:Workflow.

The main class here is a wfprov:WorkflowRun which shows how wfprov:Artifact instances (the data) wfprov:wasOutputFrom a wfprov:ProcessRun for generated artifacts, or wfprov:usedInput for consumed artifacts. The WorkflowRun is also a ProcessRun, and so the overall inputs and outputs of thw workflow execution can be described in the same manner.

These provenance details are linked to the corresponding wfdesc descriptions using wfdesc:describedbyProcess, wfdesc:describedByWorkflow and wfdesc:describedByParameter.


This ontology can be further linked to more specific provenance ontologies like OPM-V or W3C PROV-O, but this should be done separately.


Is **THIS** Markdown _working_ correctly? If so, [this](https://google.com) is a hyperlink to Google.
"""  ;
    schema:license <http://purl.org/NET/rdflicense/cc-by3.0> ;
    schema:name "Workflow 4Ever Provenance Ontology" ;
    schema:publisher <https://wf4ever.github.io> ;
    schema:version "0.1.2" ;
    skos:historyNote """<p>2026-06: added this HTML literal history note for testing</p>
<p>2026-05: a fake history note for testing</p>
<p>Foods Nick likes:</p>
<ul>
   <li>smoked chicken</li>
   <li>gorgonzola cheese</li>
</ul>"""^^rdf:HTML ;
.

<https://wf4ever.github.io>
    a schema:Organization ;
    schema:name "Workflow 4Ever Project Team" ;
    schema:url "https://wf4ever.github.io/"^^xsd:anyURI ;
.

<https://ror.org/00yczwp93>
    a schema:Organization ;
    schema:name "Laboratoire en Sciences et Technologies de l'Information Géographique pour la ville intelligente et les territoires durables" ;
.